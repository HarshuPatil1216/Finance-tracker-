rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['uid', 'email'])
        && incoming().uid == request.auth.uid
        && incoming().email.size() <= 256;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid;
    }

    // 2. Transactions Collection
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid
          && data.type in ['income', 'expense']
          && data.amount is number && data.amount >= 0
          && data.category is string && data.category.size() <= 50
          && data.date is string;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidTransaction(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 3. Budgets Collection
    match /budgets/{budgetId} {
      function isValidBudget(data) {
        return data.userId == request.auth.uid
          && data.category is string && data.category.size() <= 50
          && data.amount is number && data.amount >= 0
          && data.month is string && data.month.size() <= 7; // YYYY-MM
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBudget(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidBudget(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 4. Bills Collection
    match /bills/{billId} {
      function isValidBill(data) {
        return data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 100
          && data.amount is number && data.amount >= 0
          && data.dueDate is string
          && data.status in ['paid', 'unpaid'];
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBill(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidBill(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
