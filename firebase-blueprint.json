{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget per category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "amount", "month"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Upcoming payment or bill",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "amount", "dueDate", "status"]
    },
    "MoneyFlow": {
      "title": "MoneyFlow",
      "description": "Borrow or Lend records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "personName": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["give", "take"] },
        "status": { "type": "string", "enum": ["pending", "settled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "personName", "amount", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User category budgets"
    },
    "/bills/{billId}": {
      "schema": "Bill",
      "description": "Scheduled bills and payments"
    },
    "/moneyFlow/{flowId}": {
      "schema": "MoneyFlow",
      "description": "Lend/Borrow Flow"
    }
  }
}
